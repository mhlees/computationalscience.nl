    <item>
      <title>Community</title>
      <link>http://localhost:1313/community/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      
      <guid>http://localhost:1313/community/</guid>
      <description>&lt;div style=&#34;width: 100%; margin: 0 auto; padding: 0 1rem;&#34;&gt;&#xA;&lt;h1 style=&#34;text-align: center; margin-bottom: 2rem;&#34;&gt;Community&lt;/h1&gt;&#xA;&lt;div style=&#34;width: min(56rem, 100%); margin: 0 auto;&#34;&gt;&#xA;&lt;p class=&#34;text-center text-lg&#34;&gt;Our group actively contributes to a broader computational science ecosystem through research networks, institutes, conferences, and journals. Below are key associations that connect our work to the international community.&lt;/p&gt;&#xA;&lt;div class=&#34;mt-8&#34; style=&#34;display: flex; flex-direction: column; align-items: center; gap: 1rem;&#34;&gt;&#xA;&lt;a href=&#34;https://www.computationalsciencenl.nl/en/&#34; target=&#34;_blank&#34; rel=&#34;noopener noreferrer&#34; class=&#34;block rounded-xl p-3 transition-shadow&#34; style=&#34;width: fit-content; max-width: min(40rem, 100%);&#34;&gt;&#xA;&lt;div class=&#34;flex items-center gap-3 justify-center&#34; style=&#34;width: fit-content; margin: 0 auto;&#34;&gt;&#xA;&lt;img src=&#34;http://localhost:1313/community/logos/computationalsciencenl.jpg&#34; alt=&#34;Computational Science NL&#34; class=&#34;h-10 w-auto object-contain shrink-0&#34;&gt;&#xA;&lt;div&gt;&#xA;&lt;h2 class=&#34;text-xl font-semibold mb-1&#34;&gt;Computational Science NL&lt;/h2&gt;&#xA;&lt;p class=&#34;text-base text-neutral-700 dark:text-neutral-300&#34;&gt;A Dutch platform that connects computational science researchers, events, and initiatives across institutions.&lt;/p&gt;</description>
      
    </item>
    
